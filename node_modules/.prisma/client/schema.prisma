datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Voici le modèle pour tes bacs à ordures intelligents
model TrashBin {
  id        String   @id @default(uuid())
  name      String // Exemple: "Bac Rue des Fleurs"
  latitude  Float // Pour la localisation GPS
  longitude Float // Pour la localisation GPS
  fillLevel Float    @default(0.0) // Niveau de remplissage en % (via le capteur de distance)
  battery   Float    @default(100.0) // Niveau de la batterie solaire en %
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
