generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Module BINS (Gestion des bacs à ordures)
model Bin {
  id        String   @id @default(uuid())
  longitude Float
  latitude  Float
  status    String   @default("EMPTY") // EMPTY, HALF, FULL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
}

// Module REPORTS (Gestion des signalements de citoyens)
model Report {
  id          String   @id @default(uuid())
  description String?
  imageUrl    String?
  status      String   @default("PENDING") // PENDING, VALIDATED, RESOLVED
  binId       String
  bin         Bin      @relation(fields: [binId], references: [id])
  createdAt   DateTime @default(now())
}